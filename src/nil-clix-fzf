#!/usr/bin/env bash
set -euo pipefail

# Interactive nil/clix command runner backed by fzf.
#
# Usage:
#   nil-clix-fzf <binary> [initial args...]
#
# Example:
#   nil-clix-fzf ./bin/sandbox
#
# The script discovers options and subcommands from "<binary> [sub...] .fzf",
# allows selecting them with fzf, and executes the final command.

if [[ -z "${BASH_VERSION:-}" ]]; then
    echo "error: nil-clix-fzf requires bash" >&2
    exit 1
fi

if [[ "${BASH_SOURCE[0]}" != "$0" ]]; then
    echo "error: nil-clix-fzf must be executed, not sourced" >&2
    return 1
fi

declare -a _nil_clix_used_options=()
declare -a _nil_clix_cmd=()
declare -a _nil_clix_text_arg_flags=()
declare -a _nil_clix_undo_steps=()
declare -a _nil_clix_subcmds=()
declare -a _nil_clix_row_fields=()
declare _nil_clix_last_token='EXEC'
declare _nil_clix_fzf_output=''
declare _nil_clix_input_header=''

_usage() {
    cat <<'EOF'
Usage: fzf-clix <binary> [initial args...]

Interactively build a nil/clix command with fzf and execute it.

Controls inside picker:
  - pick an item: add argument
  - [EXEC]: execute command
  - [UNDO]: undo last step
  - [QUIT]: exit without running
EOF
}

_cmd_prompt() {
    printf '$'
    local index
    local escaped_arg
    for (( index=0; index<${#_nil_clix_cmd[@]}; index++ )); do
        if [[ "${_nil_clix_text_arg_flags[$index]:-0}" == "1" ]]; then
            escaped_arg="${_nil_clix_cmd[$index]//\\/\\\\}"
            escaped_arg="${escaped_arg//\"/\\\"}"
            printf ' "%s"' "$escaped_arg"
        else
            printf ' %q' "${_nil_clix_cmd[$index]}"
        fi
    done
    printf ' > '
}

_nil_clix_parse_row() {
    local remainder="$1"

    _nil_clix_row_fields=()
    while [[ "$remainder" == *$'\t'* ]]; do
        _nil_clix_row_fields+=("${remainder%%$'\t'*}")
        remainder="${remainder#*$'\t'}"
    done
    _nil_clix_row_fields+=("$remainder")
}

_formatted_row_token() {
    _nil_clix_parse_row "$1"

    local token="${_nil_clix_row_fields[1]:-}"
    token="${token#"${token%%[![:space:]]*}"}"
    token="${token%"${token##*[![:space:]]}"}"
    printf '%s' "$token"
}

_candidate_position() {
    local candidates="$1"
    local token="$2"
    local line_number=0
    local entry
    local entry_token

    while IFS= read -r entry; do
        line_number=$((line_number + 1))
        entry_token=$(_formatted_row_token "$entry")
        if [[ "$entry_token" == "$token" ]]; then
            printf '%s' "$line_number"
            return 0
        fi
    done <<< "$candidates"

    return 1
}

_die() {
    echo "error: $1" >&2
    exit 1
}

_nil_clix_option_candidates() {
    awk -F '\t' 'NF >= 7 && $2 ~ /^--/ { print }' <<< "$1"
}

_nil_clix_option_is_repeatable() {
    local value_type="$1"
    local implicit="$2"

    [[ "$value_type" == "t" && -z "$implicit" ]]
}

_nil_clix_subcommand_candidates() {
    awk -F '\t' 'NF >= 7 && $2 !~ /^--/ { print }' <<< "$1"
}

_nil_clix_format_candidates() {
    awk -F '\t' '
        {
            col1[NR] = $1
            col2[NR] = $2
            col3[NR] = $3
            col4[NR] = $4
            col7[NR] = $7

            if (length(col2[NR]) > width2) {
                width2 = length(col2[NR])
            }
            if (length(col4[NR]) > width4) {
                width4 = length(col4[NR])
            }
        }

        END {
            for (row_index = 1; row_index <= NR; row_index++) {
                printf "%s %-*s %s  %-*s  %s\t%s\n",
                    col1[row_index],
                    width2, col2[row_index],
                    col3[row_index],
                    width4, col4[row_index],
                    col7[row_index],
                    col2[row_index]
            }
        }
    '
}

_nil_clix_option_row() {
    local fzf_output="$1"
    local token="$2"

    awk -F '\t' -v token="$token" 'NF >= 7 && $2 == token { print; exit }' <<< "$fzf_output"
}

_nil_clix_option_repeatable() {
    local fzf_output="$1"
    local token="$2"
    local option_row
    local value_type
    local implicit

    option_row=$(_nil_clix_option_row "$fzf_output" "$token")
    [[ -z "$option_row" ]] && return 1

    _nil_clix_parse_row "$option_row"
    value_type="${_nil_clix_row_fields[4]:-}"
    implicit="${_nil_clix_row_fields[5]:-}"
    _nil_clix_option_is_repeatable "$value_type" "$implicit"
}

_nil_clix_option_value_kind() {
    local fzf_output="$1"
    local token="$2"
    local option_row
    local value_type
    local implicit

    option_row=$(_nil_clix_option_row "$fzf_output" "$token")
    [[ -z "$option_row" ]] && { echo none; return; }

    _nil_clix_parse_row "$option_row"
    value_type="${_nil_clix_row_fields[4]:-}"
    implicit="${_nil_clix_row_fields[5]:-}"

    case "$value_type" in
        i)
            if [[ -n "$implicit" ]]; then
                echo optional-value
            else
                echo required-value
            fi
            ;;
        t)
            echo required-text
            ;;
        *)
            echo none
            ;;
    esac
}

_nil_clix_option_implicit_value() {
    local fzf_output="$1"
    local token="$2"
    local option_row
    local implicit

    option_row=$(_nil_clix_option_row "$fzf_output" "$token")
    [[ -z "$option_row" ]] && return 0

    _nil_clix_parse_row "$option_row"
    implicit="${_nil_clix_row_fields[5]:-}"
    if [[ -n "$implicit" ]]; then
        printf '%s' "$implicit"
    fi
}

_nil_clix_option_is_used() {
    local token="$1"
    local used_token

    for used_token in "${_nil_clix_used_options[@]}"; do
        if [[ "$used_token" == "$token" ]]; then
            return 0
        fi
    done

    return 1
}

_nil_clix_refresh_used_options() {
    local fzf_output="$1"
    shift

    _nil_clix_used_options=()

    local arg
    for arg in "$@"; do
        [[ "$arg" == -* ]] || continue

        if _nil_clix_option_repeatable "$fzf_output" "$arg"; then
            continue
        fi

        if ! _nil_clix_option_is_used "$arg"; then
            _nil_clix_used_options+=("$arg")
        fi
    done
}

_nil_clix_visible_option_candidates() {
    local fzf_output="$1"
    local option_row
    local token
    local value_type
    local implicit

    while IFS= read -r option_row; do
        _nil_clix_parse_row "$option_row"
        token="${_nil_clix_row_fields[1]:-}"
        [[ -z "$token" ]] && continue

        value_type="${_nil_clix_row_fields[4]:-}"
        implicit="${_nil_clix_row_fields[5]:-}"

        if _nil_clix_option_is_used "$token"; then
            if ! _nil_clix_option_is_repeatable "$value_type" "$implicit"; then
                continue
            fi
        fi

        printf '%s\n' "$option_row"
    done < <(_nil_clix_option_candidates "$fzf_output")
}

_nil_clix_requires_value() {
    local value_kind="$1"
    [[ "$value_kind" == required-* || "$value_kind" == optional-* ]]
}

_nil_clix_value_is_optional() {
    local value_kind="$1"
    [[ "$value_kind" == optional-* ]]
}

_nil_clix_value_is_text() {
    local value_kind="$1"
    [[ "$value_kind" == *-text || "$value_kind" == *-texts ]]
}

_nil_clix_value_is_number() {
    local value_kind="$1"
    [[ "$value_kind" == *-value ]]
}

_nil_clix_is_integer() {
    local value="$1"
    [[ "$value" =~ ^-?[0-9]+$ ]]
}

_nil_clix_read_option_value() {
    local token="$1"
    local value_kind="$2"
    local allow_empty='false'
    local prompt_suffix=''
    local opt_value
    local implicit_value

    if _nil_clix_value_is_optional "$value_kind"; then
        allow_empty='true'
        implicit_value=$(_nil_clix_option_implicit_value "$_nil_clix_fzf_output" "$token")
        if [[ -n "$implicit_value" ]]; then
            prompt_suffix=" (empty = ${implicit_value})"
        else
            prompt_suffix=' (empty = implicit)'
        fi
    fi

    while true; do
        opt_value=$(_read_free_arg "${token}>${prompt_suffix} " "$allow_empty")

        if [[ -z "$opt_value" ]]; then
            if [[ "$value_kind" == "required-value" ]]; then
                _nil_clix_input_header="error: ${token} requires an integer value"
                continue
            fi
            if [[ "$value_kind" == "required-text" ]]; then
                _nil_clix_input_header="error: ${token} requires a value"
                continue
            fi
            _nil_clix_input_header=''
            printf '%s' "$opt_value"
            return 0
        fi

        if ! _nil_clix_value_is_number "$value_kind" || _nil_clix_is_integer "$opt_value"; then
            _nil_clix_input_header=''
            printf '%s' "$opt_value"
            return 0
        fi

        _nil_clix_input_header="error: ${token} expects an integer value"
    done
}

_build_subcmd_chain() {
    _nil_clix_subcmds=()
    local i
    for (( i=1; i<${#_nil_clix_cmd[@]}; i++ )); do
        [[ "${_nil_clix_cmd[$i]}" == -* ]] && break
        _nil_clix_subcmds+=("${_nil_clix_cmd[$i]}")
    done
}

_read_free_arg() {
    local prompt="$1"
    local allow_empty="${2:-false}"
    local value
    local -a fzf_args=(
        --print-query
        --prompt "$prompt"
        --height=~30%
        --layout=reverse
    )

    if [[ -n "$_nil_clix_input_header" ]]; then
        fzf_args+=(--header "$_nil_clix_input_header")
    fi

    value=$(printf '' | fzf "${fzf_args[@]}" | head -1)
    if [[ "$allow_empty" == "true" ]]; then
        printf '%s' "$value"
        return 0
    fi
    [[ -n "$value" ]] && printf '%s' "$value"
}

_pop_cmd_args() {
    local count="$1"
    local index
    for (( index=0; index<count; index++ )); do
        if [[ ${#_nil_clix_cmd[@]} -le 1 ]]; then
            break
        fi
        unset '_nil_clix_cmd[${#_nil_clix_cmd[@]}-1]'
        _nil_clix_cmd=("${_nil_clix_cmd[@]}")
        unset '_nil_clix_text_arg_flags[${#_nil_clix_text_arg_flags[@]}-1]'
        _nil_clix_text_arg_flags=("${_nil_clix_text_arg_flags[@]}")
    done
}

_init_text_flags() {
    local index
    _nil_clix_text_arg_flags=()
    for (( index=0; index<${#_nil_clix_cmd[@]}; index++ )); do
        _nil_clix_text_arg_flags+=(0)
    done
}

_nil_clix_has_selected_option() {
    local arg

    for arg in "$@"; do
        if [[ "$arg" == -* ]]; then
            return 0
        fi
    done

    return 1
}

_build_candidates() {
    local has_selected_option="$1"

    {
        printf '[\tEXEC\t]\t\t\t\tExecute current command\n'
        if [[ ${#_nil_clix_undo_steps[@]} -gt 0 ]]; then
            printf '[\tUNDO\t]\t\t\t\tUndo last step\n'
        fi
        printf '[\tQUIT\t]\t\t\t\tExit without running\n'
        _nil_clix_visible_option_candidates "$_nil_clix_fzf_output"
        if [[ "$has_selected_option" != "true" ]]; then
            _nil_clix_subcommand_candidates "$_nil_clix_fzf_output"
        fi
    } | _nil_clix_format_candidates
}

_select_candidate() {
    local candidates="$1"
    local prompt="$2"
    local last_token="$3"
    local start_position=''
    local -a fzf_args

    start_position=$(_candidate_position "$candidates" "$last_token" || true)

    fzf_args=(
        --delimiter=$'\t'
        --with-nth=1
        --height=~45%
        --layout=reverse
        --border
        --prompt="$prompt"
        --info=inline
    )
    if [[ -n "$start_position" ]]; then
        fzf_args+=(--bind "start:pos($start_position)")
    fi

    echo "$candidates" | fzf "${fzf_args[@]}"
}

main() {
    if [[ $# -lt 1 ]]; then
        _usage
        exit 1
    fi

    if ! command -v fzf >/dev/null 2>&1; then
        _die "fzf is required"
    fi

    _nil_clix_cmd=("$@")
    _nil_clix_text_arg_flags=()
    _nil_clix_undo_steps=()
    _nil_clix_last_token='EXEC'
    if [[ ! -x "${_nil_clix_cmd[0]}" ]] && ! command -v "${_nil_clix_cmd[0]}" >/dev/null 2>&1; then
        _die "binary not found: ${_nil_clix_cmd[0]}"
    fi

    if [[ ${#_nil_clix_cmd[@]} -gt 1 ]]; then
        local initial_index
        for (( initial_index=1; initial_index<${#_nil_clix_cmd[@]}; initial_index++ )); do
            _nil_clix_undo_steps+=(1)
        done
    fi
    _init_text_flags

    while true; do
        _build_subcmd_chain

        _nil_clix_fzf_output=$("${_nil_clix_cmd[0]}" "${_nil_clix_subcmds[@]}" .fzf 2>/dev/null || true)
        if [[ -z "$_nil_clix_fzf_output" ]]; then
            _die "unable to resolve .fzf context: ${_nil_clix_subcmds[*]}"
        fi

        _nil_clix_refresh_used_options "$_nil_clix_fzf_output" "${_nil_clix_cmd[@]:1}"

        local has_selected_option='false'
        if _nil_clix_has_selected_option "${_nil_clix_cmd[@]:1}"; then
            has_selected_option='true'
        fi

        local candidates
        candidates=$(_build_candidates "$has_selected_option")

        local selected
        selected=$(_select_candidate "$candidates" "$(_cmd_prompt)" "$_nil_clix_last_token")

        [[ -z "$selected" ]] && continue

        local token=''
        token=$(_formatted_row_token "$selected")

        case "$token" in
            'EXEC')
                echo "exec -- ${_nil_clix_cmd[@]}"
                exec "${_nil_clix_cmd[@]}"
                ;;
            'UNDO')
                _nil_clix_last_token='UNDO'
                if [[ ${#_nil_clix_undo_steps[@]} -gt 0 ]]; then
                    local undo_count="${_nil_clix_undo_steps[${#_nil_clix_undo_steps[@]}-1]}"
                    unset '_nil_clix_undo_steps[${#_nil_clix_undo_steps[@]}-1]'
                    _nil_clix_undo_steps=("${_nil_clix_undo_steps[@]}")
                    _pop_cmd_args "$undo_count"
                fi
                ;;
            'QUIT')
                exit 0
                ;;
            *)
                _nil_clix_cmd+=("$token")
                _nil_clix_text_arg_flags+=(0)
                local added_count=1
                if [[ "$token" == -* ]]; then
                    _nil_clix_last_token="$token"
                    local value_kind
                    value_kind=$(_nil_clix_option_value_kind "$_nil_clix_fzf_output" "$token")

                    if _nil_clix_requires_value "$value_kind"; then
                        local opt_value
                        opt_value=$(_nil_clix_read_option_value "$token" "$value_kind")
                        if [[ -n "$opt_value" ]]; then
                            _nil_clix_cmd+=("$opt_value")
                            if _nil_clix_value_is_text "$value_kind"; then
                                _nil_clix_text_arg_flags+=(1)
                            else
                                _nil_clix_text_arg_flags+=(0)
                            fi
                            added_count=2
                        elif ! _nil_clix_value_is_optional "$value_kind"; then
                            _pop_cmd_args 1
                            added_count=0
                        fi
                    fi
                else
                    _nil_clix_last_token=''
                fi
                if [[ "$added_count" -gt 0 ]]; then
                    _nil_clix_undo_steps+=("$added_count")
                fi
                ;;
        esac
    done
}

main "$@"